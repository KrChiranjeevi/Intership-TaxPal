// prisma/schema.prisma

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                   @id @default(uuid())
  username             String?                  @unique
  name                 String
  email                String                   @unique
  password             String
  country              String?
  incomeBracket        String?
  twoFactorEnabled     Boolean                  @default(false)
  createdAt            DateTime                 @default(now())
  refreshTokens        RefreshToken[]
  transactions         Transaction[]
  budgets              Budget[] // This line links the User model to the new Budget model.
  categories           Category[]
  notificationSettings UserNotificationSetting?
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Transaction {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  type        String // "income" | "expense"
  category    String?
  description String
  amount      Float
  date        DateTime
  notes       String? // optional (free text)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// This is the new Budget model that aligns with your existing schema.
model Budget {
  id          String   @id @default(uuid())
  category    String
  amount      Float
  month       DateTime
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Category {
  id        String   @id @default(uuid())
  name      String
  type      String // "income" | "expense"
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model UserNotificationSetting {
  id                 String   @id @default(uuid())
  userId             String   @unique // <--- must be unique for one-to-one
  emailNotifications Boolean  @default(true)
  transactionAlerts  Boolean  @default(true)
  budgetWarnings     Boolean  @default(true)
  taxReminders       Boolean  @default(true)
  user               User     @relation(fields: [userId], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
