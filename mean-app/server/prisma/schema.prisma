generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                   @id @default(uuid())
  name                 String
  email                String                   @unique
  password             String
  country              String?
  incomeBracket        String?
  createdAt            DateTime                 @default(now())
  username             String?                  @unique
  twoFactorEnabled     Boolean                  @default(false)
  budgets              Budget[]
  categories           Category[]
  refreshTokens        RefreshToken[]
  transactions         Transaction[]
  notificationSettings UserNotificationSetting?
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id          String   @id @default(uuid())
  type        String
  amount      Float
  category    String?
  date        DateTime
  createdAt   DateTime @default(now())
  userId      String
  description String
  notes       String?
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Budget {
  id          String   @id @default(uuid())
  category    String
  amount      Float
  month       DateTime
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Category {
  id        String   @id @default(uuid())
  name      String
  type      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  color     String?
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model UserNotificationSetting {
  id                 String   @id @default(uuid())
  userId             String   @unique
  emailNotifications Boolean  @default(true)
  transactionAlerts  Boolean  @default(true)
  budgetWarnings     Boolean  @default(true)
  taxReminders       Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id])
}
