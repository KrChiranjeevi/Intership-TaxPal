// prisma/schema.prisma

// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(uuid())
  username        String?        @unique
  name            String
  email           String         @unique
  password        String
  country         String?
  incomeBracket   String?
  createdAt       DateTime       @default(now())
  refreshTokens   RefreshToken[]
  transactions    Transaction[]
  budgets         Budget[]       // This line links the User model to the new Budget model.
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Transaction {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  type        String   // "income" | "expense"
  category    String?
  description String
  amount      Float
  date        DateTime
  notes       String?  // optional (free text)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// This is the new Budget model that aligns with your existing schema.
model Budget {
  id          String   @id @default(uuid())
  category    String
  amount      Float
  month       DateTime
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}
model TaxEstimate {
  id                    String   @id @default(uuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  country               String   @default("United States")
  state                 String?
  status                String   @default("Single") // e.g., 'Single', 'Married Filing Jointly'
  quarter               String   @default("Q1") // 'Q1', 'Q2', 'Q3', 'Q4'
  year                  Int
  income                Float
  businessExpenses      Float    @default(0)
  retirement            Float    @default(0)
  healthInsurance       Float    @default(0)
  homeOffice            Float    @default(0)
  additionalDeductions  Float    @default(0)
  // Calculated fields
  taxableIncome         Float
  estimatedTax          Float
  effectiveTaxRate      Float
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
}

