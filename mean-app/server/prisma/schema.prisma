generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                   @id @default(uuid())
  name                 String
  email                String                   @unique
  password             String
  country              String?
  incomeBracket        String?
  createdAt            DateTime                 @default(now())
  username             String?                  @unique
  twoFactorEnabled     Boolean                  @default(false)
  budgets              Budget[]
  categories           Category[]
  refreshTokens        RefreshToken[]
  transactions         Transaction[]
  notificationSettings UserNotificationSetting?
  taxEstimates         TaxEstimate[]
  reports              Report[] // relation to Report
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id          String   @id @default(uuid())
  type        String
  amount      Float
  category    String?
  date        DateTime
  createdAt   DateTime @default(now())
  userId      String
  description String
  notes       String?
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  // 👇 Added this for Report relation
  reportId    String?
  report      Report?   @relation(fields: [reportId], references: [id])

  @@index([userId])
  @@index([reportId])
}

model Budget {
  id          String   @id @default(uuid())
  category    String
  amount      Float
  spent       Float    @default(0) // <-- add this
  month       DateTime
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Category {
  id        String   @id @default(uuid())
  name      String
  type      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  color     String?
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model UserNotificationSetting {
  id                 String   @id @default(uuid())
  userId             String   @unique
  emailNotifications Boolean  @default(true)
  transactionAlerts  Boolean  @default(true)
  budgetWarnings     Boolean  @default(true)
  taxReminders       Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id])
}

model TaxEstimate {
  id                   String   @id @default(uuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  country              String   @default("United States")
  state                String?
  status               String   @default("Single") // e.g., 'Single', 'Married Filing Jointly'
  quarter              String   @default("Q1") // 'Q1', 'Q2', 'Q3', 'Q4'
  year                 Int
  income               Float
  businessExpenses     Float    @default(0)
  retirement           Float    @default(0)
  healthInsurance      Float    @default(0)
  homeOffice           Float    @default(0)
  additionalDeductions Float    @default(0)
  taxableIncome        Float
  estimatedTax         Float
  effectiveTaxRate     Float
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
}

model Report {
  id           String         @id @default(uuid())
  userId       String
  reportType   String
  period       String
  color        String?
  format       String
  filePath     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  generatedAt  DateTime @default(now())
  name         String?
  transactions Transaction[]   // 👈 now valid relation
  user         User @relation(fields: [userId], references: [id])

  @@index([userId])
}
